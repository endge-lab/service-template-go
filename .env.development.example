# Base runtime identity.
APP_ENV=development
APP_NAME=service_template
APP_VERSION=0.1.0
REST_PORT=8080
LOGGER_LEVEL=debug
PUBLIC_URL=http://localhost:8080

# Comma-separated browser origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL is optional until the concrete service adds repositories.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=service_template
POSTGRES_SCHEMA=public
POSTGRES_SSLMODE=disable
POSTGRES_MIGRATIONS_ENABLED=false

# Auth is optional.
AUTH_ENABLED=false
AUTH_SERVICE_URL=
AUTH_ISSUER=
AUTH_ALLOWED_AUDIENCES=
AUTH_JWKS_PATH=/.well-known/jwks.json
AUTH_JWKS_CACHE_TTL=5m
AUTH_SERVICE_TIMEOUT=5s

# OpenTelemetry is optional and disabled by default.
TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true

# Redpanda/Kafka is optional and disabled by default.
REDPANDA_ENABLED=false
REDPANDA_BROKERS=
REDPANDA_CLIENT_ID=service_template
REDPANDA_DIAL_TIMEOUT=5s
REDPANDA_READ_BATCH_TIMEOUT=2s
REDPANDA_WRITE_TIMEOUT=10s
